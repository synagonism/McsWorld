          "searchString": "<h", "isRegex": false,
          "matchWholeWord": false, "isCaseSensitive": false, "findInSelection": false
         }
      },
      "editor.action.nextMatchFindAction",
      "closeFindWidget",
      "cursorRight",
      "cursorRightSelect",
      "editor.emmet.action.decrementNumberByOne",
      { "command": "editor.action.clipboardCopyAction", "await": "clipboard" },
      "cursorWordEndRight",
      "cursorWordEndRight",
      "cursorWordEndRight",
      "deleteLeft",
      { "command": "editor.action.clipboardPasteAction", "await": "document selection" },
      "cursorDown",
      "cursorEnd",
      "cursorLeft",
      "deleteLeft",
      { "command": "editor.action.clipboardPasteAction", "await": "document selection" },
      "cursorWordLeft",
      "cursorWordLeft",
      "cursorWordLeft",
      "cursorWordLeft",
      "deleteLeft",
      { "command": "editor.action.clipboardPasteAction", "await": "document selection" },
      "cursorEnd",
    ]
  },
  "when": "editorTextFocus"
},
